<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Blogger</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <div>
          <a href="/" class="brand">Blogger</a>
          <p class="hero-text">Real blog pages with a Node.js backend.</p>
        </div>
        <nav class="site-nav">
          <a href="/">Home</a>
          <a href="/admin">Post update</a>
          <a href="/login">Login</a>
          <a href="/logout">Logout</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <%- body %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>Built with Express and EJS.</p>
      </div>
    </footer>
  </body>
</html>
