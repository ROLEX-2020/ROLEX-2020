<%- include('layout', {
  title: 'Admin',
  body: `
    <section class="intro">
      <h1>Post Live Updates</h1>
      <p>Create a new update and publish it instantly to the site.</p>
    </section>

    <section class="admin-grid">
      <div class="admin-form card">
        <h2>New update</h2>
        <form method="POST" action="/admin">
          <label>
            Title
            <input type="text" name="title" required placeholder="Post title" />
          </label>
          <label>
            Excerpt
            <input type="text" name="excerpt" placeholder="Brief summary (optional)" />
          </label>
          <label>
            Content
            <textarea name="content" rows="10" required placeholder="Write your post here..."></textarea>
          </label>
          <button type="submit">Publish update</button>
        </form>
      </div>

      <div class="admin-list card">
        <h2>Published posts</h2>
        <div class="post-list">
          ${posts
            .map(
              (post) =>
                `<article class="post-preview">
                  <h3>${post.title}</h3>
                  <time datetime="${post.publishDate}">${post.publishDate}</time>
                  <p>${post.excerpt}</p>
                  <a href="/post/${post.id}">View</a>
                </article>`
            )
            .join('')}
        </div>
      </div>
    </section>
  `
}) %>
